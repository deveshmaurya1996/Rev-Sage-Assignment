# Copy to `.env` in this directory (repo root) for Docker Compose variable substitution.

# PostgreSQL superuser name (must match DATABASE_USER for the backend container).
POSTGRES_USER=postgres
# PostgreSQL password for that user.
POSTGRES_PASSWORD=postgres
# Initial database name created on first Postgres startup.
POSTGRES_DB=revsage
# Host port mapped to Postgres (default 5432).
POSTGRES_PORT=5432

# Host port mapped to Redis (default 6379).
REDIS_PORT=6379

# Host port for the NestJS API (maps container 3001).
BACKEND_PORT=3001
# Host port for the Next.js app (maps container 3000).
FRONTEND_PORT=3000

# Secret for signing JWT access tokens (use a long random string in production).
JWT_SECRET=replace-with-a-long-random-string
# JWT lifetime in seconds (e.g. 604800 = 7 days).
JWT_EXPIRES_SEC=604800

# If true, TypeORM may sync schema to the database (dev/demo only; turn off in production).
DATABASE_SYNC=true

# Browser-reachable API base URL baked into the frontend image at build time (use host + BACKEND_PORT from the machine running the browser).
NEXT_PUBLIC_API_URL=http://localhost:3001
