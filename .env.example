# Docker Compose — copy to `.env` in this directory (repo root).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=revsage
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=3001
FRONTEND_PORT=3000

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_SEC=604800
DATABASE_SYNC=true

NEXT_PUBLIC_API_URL=http://localhost:3001
