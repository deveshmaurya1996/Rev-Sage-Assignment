# Copy to `backend/.env` for local `npm run start:dev` (not used by Docker Compose).

# HTTP port for the NestJS server.
PORT=3001

# PostgreSQL connection (use `postgres` as host when DB runs in Docker on the same compose network).
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=revsage

# If true, TypeORM may auto-sync schema (dev only; disable in production).
DATABASE_SYNC=true

# Optional: enable SQL logging (uncomment to use).
# TYPEORM_LOGGING=true

# Redis host/port for BullMQ (use `redis` as host when Redis runs in Docker).
REDIS_HOST=localhost
REDIS_PORT=6379

# Secret for JWT signing; must match what you expect in tokens.
JWT_SECRET=replace-with-a-long-random-string
# Access token expiry in seconds.
JWT_EXPIRES_SEC=604800

# development | production | test
NODE_ENV=development
